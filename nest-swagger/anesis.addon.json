{
  "$schema": "https://anesis-server-maksym-zhuk8433-w6h7le9s.leapcell.dev/schema/anesis.addon.schema.json",
  "schema_version": "1",
  "id": "nest-swagger",
  "name": "Nest Swagger",
  "version": "0.1.0",
  "description": "Adds @nestjs/swagger and exposes Swagger UI at /api in a NestJS project",
  "author": "anesis-cli",
  "requires": [],
  "inputs": [],
  "detect": [
    {
      "id": "fastify",
      "rules": [
        {
          "type": "json_contains",
          "file": "package.json",
          "key_path": "dependencies.@nestjs/platform-fastify"
        }
      ],
      "match": "all"
    }
  ],
  "variants": [
    {
      "when": "fastify",
      "commands": [
        {
          "name": "install",
          "description": "Installs @nestjs/swagger + @fastify/static and sets up Swagger UI at /api",
          "once": true,
          "requires_commands": [],
          "inputs": [],
          "steps": [
            {
              "type": "replace",
              "target": { "type": "file", "file": "package.json" },
              "find": "\"dependencies\": {",
              "replace": "\"dependencies\": {\n    \"@nestjs/swagger\": \"^11.0.3\",\n    \"@fastify/static\": \"^8.1.0\",",
              "if_not_found": "skip"
            },
            {
              "type": "inject",
              "target": { "type": "file", "file": "src/main.ts" },
              "content": "import { SwaggerModule, DocumentBuilder } from '@nestjs/swagger';",
              "after": "from './app.module'",
              "if_not_found": "error"
            },
            {
              "type": "inject",
              "target": { "type": "file", "file": "src/main.ts" },
              "content": "  const swaggerConfig = new DocumentBuilder()\n    .setTitle('API')\n    .setDescription('API description')\n    .setVersion('1.0')\n    .addBearerAuth()\n    .build();\n  const document = SwaggerModule.createDocument(app, swaggerConfig);\n  SwaggerModule.setup('api', app, document);",
              "before": "await app.listen",
              "if_not_found": "error"
            }
          ]
        }
      ]
    },
    {
      "when": null,
      "commands": [
        {
          "name": "install",
          "description": "Installs @nestjs/swagger and sets up Swagger UI at /api",
          "once": true,
          "requires_commands": [],
          "inputs": [],
          "steps": [
            {
              "type": "replace",
              "target": { "type": "file", "file": "package.json" },
              "find": "\"dependencies\": {",
              "replace": "\"dependencies\": {\n    \"@nestjs/swagger\": \"^11.0.3\",",
              "if_not_found": "skip"
            },
            {
              "type": "inject",
              "target": { "type": "file", "file": "src/main.ts" },
              "content": "import { SwaggerModule, DocumentBuilder } from '@nestjs/swagger';",
              "after": "from './app.module'",
              "if_not_found": "error"
            },
            {
              "type": "inject",
              "target": { "type": "file", "file": "src/main.ts" },
              "content": "  const swaggerConfig = new DocumentBuilder()\n    .setTitle('API')\n    .setDescription('API description')\n    .setVersion('1.0')\n    .addBearerAuth()\n    .build();\n  const document = SwaggerModule.createDocument(app, swaggerConfig);\n  SwaggerModule.setup('api', app, document);",
              "before": "await app.listen",
              "if_not_found": "error"
            }
          ]
        }
      ]
    }
  ]
}
