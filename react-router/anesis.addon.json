{
  "$schema": "https://anesis-server-maksym-zhuk8433-w6h7le9s.leapcell.dev/schema/anesis.addon.schema.json",
  "schema_version": "1",
  "id": "react-router",
  "name": "React Router",
  "version": "0.2.0",
  "description": "Adds React Router v7 to a React project — sets up BrowserRouter, rewrites App.tsx with Routes, and provides a page generator that wires routes automatically.",
  "author": "anesis-dev",
  "requires": [],
  "inputs": [],
  "detect": [],
  "variants": [
    {
      "when": null,
      "commands": [
        {
          "name": "install",
          "description": "Installs react-router v7, adds BrowserRouter to main.tsx, rewrites App.tsx with Routes and starter pages",
          "once": true,
          "requires_commands": [],
          "inputs": [],
          "steps": [
            {
              "type": "replace",
              "target": { "type": "file", "file": "package.json" },
              "find": "\"dependencies\": {",
              "replace": "\"dependencies\": {\n    \"react-router\": \"^7.6.0\",",
              "if_not_found": "skip"
            },
            {
              "type": "inject",
              "target": { "type": "file", "file": "src/main.tsx" },
              "content": "import { BrowserRouter } from 'react-router';",
              "after": "// anesis:top-imports",
              "if_not_found": "error"
            },
            {
              "type": "inject",
              "target": { "type": "file", "file": "src/main.tsx" },
              "content": "    <BrowserRouter>",
              "after": "{/* anesis:providers-start */}",
              "if_not_found": "error"
            },
            {
              "type": "inject",
              "target": { "type": "file", "file": "src/main.tsx" },
              "content": "    </BrowserRouter>",
              "before": "{/* anesis:providers-end */}",
              "if_not_found": "error"
            },
            {
              "type": "create",
              "path": "src/pages/HomePage.tsx",
              "content": "export function HomePage() {\n  return (\n    <main>\n      <h1>Home</h1>\n    </main>\n  );\n}\n",
              "if_exists": "skip"
            },
            {
              "type": "create",
              "path": "src/pages/NotFoundPage.tsx",
              "content": "export function NotFoundPage() {\n  return (\n    <main>\n      <h1>404 — Page not found</h1>\n    </main>\n  );\n}\n",
              "if_exists": "skip"
            },
            {
              "type": "create",
              "path": "src/App.tsx",
              "content": "import { Route, Routes } from 'react-router';\nimport { HomePage } from './pages/HomePage';\nimport { NotFoundPage } from './pages/NotFoundPage';\n// anesis:page-imports\n\nfunction App() {\n  return (\n    <Routes>\n      {/* anesis:routes */}\n      <Route path=\"/\" element={<HomePage />} />\n      <Route path=\"*\" element={<NotFoundPage />} />\n    </Routes>\n  );\n}\n\nexport default App;\n",
              "if_exists": "overwrite"
            }
          ]
        },
        {
          "name": "generate",
          "description": "Generates a new page and wires it into App.tsx as a Route",
          "once": false,
          "requires_commands": ["install"],
          "inputs": [
            {
              "name": "page_name",
              "type": "text",
              "description": "Page name in kebab-case (e.g. about, user-profile)",
              "required": true
            },
            {
              "name": "page_path",
              "type": "text",
              "description": "URL path for the route (e.g. /about, /users/:id)",
              "required": true
            }
          ],
          "steps": [
            {
              "type": "create",
              "path": "src/pages/{{ page_name_pascal }}Page.tsx",
              "content": "export function {{ page_name_pascal }}Page() {\n  return (\n    <main>\n      <h1>{{ page_name_pascal }}</h1>\n    </main>\n  );\n}\n",
              "if_exists": "ask"
            },
            {
              "type": "inject",
              "target": { "type": "file", "file": "src/App.tsx" },
              "content": "import { {{ page_name_pascal }}Page } from './pages/{{ page_name_pascal }}Page';",
              "after": "// anesis:page-imports",
              "if_not_found": "error"
            },
            {
              "type": "inject",
              "target": { "type": "file", "file": "src/App.tsx" },
              "content": "      <Route path=\"{{ page_path }}\" element={<{{ page_name_pascal }}Page />} />",
              "after": "{/* anesis:routes */}",
              "if_not_found": "error"
            }
          ]
        }
      ]
    }
  ]
}
