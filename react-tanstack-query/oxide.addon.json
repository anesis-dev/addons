{
  "$schema": "https://oxide-server-maksym-zhuk8433-w6h7le9s.leapcell.dev/schema/oxide.addon.schema.json",
  "schema_version": "1",
  "id": "react-tanstack-query",
  "name": "React TanStack Query",
  "version": "0.1.0",
  "description": "Adds TanStack Query v5 (React Query) with a shared QueryClient, QueryClientProvider, and devtools to a React project.",
  "author": "oxide-cli",
  "requires": [],
  "inputs": [],
  "detect": [],
  "variants": [
    {
      "when": null,
      "commands": [
        {
          "name": "install",
          "description": "Installs @tanstack/react-query v5 and sets up QueryClientProvider in main.tsx",
          "once": true,
          "requires_commands": [],
          "inputs": [],
          "steps": [
            {
              "type": "replace",
              "target": { "type": "file", "file": "package.json" },
              "find": "\"dependencies\": {",
              "replace": "\"dependencies\": {\n    \"@tanstack/react-query\": \"^5.80.5\",\n    \"@tanstack/react-query-devtools\": \"^5.80.5\",",
              "if_not_found": "skip"
            },
            {
              "type": "create",
              "path": "src/lib/query-client.ts",
              "content": "import { QueryClient } from '@tanstack/react-query';\n\nexport const queryClient = new QueryClient({\n  defaultOptions: {\n    queries: {\n      staleTime: 1000 * 60,\n      retry: 1,\n    },\n  },\n});\n",
              "if_exists": "skip"
            },
            {
              "type": "inject",
              "target": { "type": "file", "file": "src/main.tsx" },
              "content": "import { QueryClientProvider } from '@tanstack/react-query';\nimport { ReactQueryDevtools } from '@tanstack/react-query-devtools';\nimport { queryClient } from './lib/query-client';",
              "after": "// oxide:top-imports",
              "if_not_found": "error"
            },
            {
              "type": "inject",
              "target": { "type": "file", "file": "src/main.tsx" },
              "content": "    <QueryClientProvider client={queryClient}>",
              "after": "{/* oxide:providers-start */}",
              "if_not_found": "error"
            },
            {
              "type": "inject",
              "target": { "type": "file", "file": "src/main.tsx" },
              "content": "      <ReactQueryDevtools initialIsOpen={false} />\n    </QueryClientProvider>",
              "before": "{/* oxide:providers-end */}",
              "if_not_found": "error"
            }
          ]
        }
      ]
    }
  ]
}
